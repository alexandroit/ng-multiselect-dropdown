{
  "name": "@revivejs/ng-multiselect-dropdown",
  "version": "6.0.1",
  "private": true,
  "description": "Angular 21 multi-select dropdown component for template-driven and reactive forms, with versioned docs for Angular 16 through 21.",
  "author": "Alexandro Paixao Marques",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4201",
    "build": "ng build",
    "ng:test": "ng test",
    "test": "ng test",
    "test:ci": "ng test --watch=false --progress=false",
    "test:coverage": "ng test --watch=false --code-coverage",
    "build:prod": "ng build --configuration production --base-href https://alexandroit.github.io/ng-multiselect-dropdown/",
    "docs:install:angular-16": "cd docs-src/angular-16 && npm install --ignore-scripts",
    "docs:install:angular-17": "cd docs-src/angular-17 && npm install --ignore-scripts",
    "docs:install:angular-18": "cd docs-src/angular-18 && npm install --ignore-scripts",
    "docs:install:angular-19": "cd docs-src/angular-19 && npm install --ignore-scripts",
    "docs:install:angular-20": "cd docs-src/angular-20 && npm install --ignore-scripts",
    "docs:install:angular-21": "cd docs-src/angular-21 && npm install --ignore-scripts",
    "build:docs:angular-16": "cd docs-src/angular-16 && npm run build",
    "build:docs:angular-17": "cd docs-src/angular-17 && npm run build",
    "build:docs:angular-18": "cd docs-src/angular-18 && npm run build",
    "build:docs:angular-19": "cd docs-src/angular-19 && npm run build",
    "build:docs:angular-20": "cd docs-src/angular-20 && npm run build",
    "build:docs:angular-21": "cd docs-src/angular-21 && npm run build",
    "build:docs:all": "npm run build:docs:angular-16 && npm run build:docs:angular-17 && npm run build:docs:angular-18 && npm run build:docs:angular-19 && npm run build:docs:angular-20 && npm run build:docs:angular-21",
    "build:docs": "npm run build:docs:angular-21",
    "clear:lib": "rimraf dist-lib",
    "copyfiles": "mkdir -p dist-lib/themes && copyfiles ng-multiselect-dropdown.theme.scss dist-lib/themes",
    "build:package": "npm run clear:lib && ng-packagr -p ng-package.json",
    "copy:package": "mkdir -p dist-lib && node scripts/merge-dist-package.js && cp README.md CHANGELOG.md dist-lib/",
    "postbuild:package": "npm run copy:package && npm run copyfiles",
    "build:lib": "npm run build:package",
    "pack:check": "npm run build:package && cd dist-lib && npm pack --dry-run",
    "publish:npm": "npm run build:package && cd dist-lib && npm publish --access public",
    "publish": "ngh --no-silent false",
    "deploy": "ng build --configuration production --base-href /ng-multiselect-dropdown/ && npm run deployOnly",
    "deployOnly": "angular-cli-ghpages --no-silent --repo=https://github.com/alexandroit/ng-multiselect-dropdown.git",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate"
  },
  "keywords": [
    "angular",
    "angular16",
    "angular17",
    "angular18",
    "angular19",
    "angular20",
    "angular21",
    "angular-16",
    "angular-17",
    "angular-18",
    "angular-19",
    "angular-20",
    "angular-21",
    "angular-library",
    "angular-component",
    "dropdown",
    "multiselect",
    "multiselect-dropdown",
    "multi-select",
    "select",
    "autocomplete",
    "forms",
    "reactive-forms",
    "template-driven-forms",
    "ngmodel",
    "search-filter",
    "searchable-dropdown",
    "select-all",
    "versioned-docs",
    "ui",
    "ui-component",
    "typescript",
    "npm-package",
    "maintained",
    "modernized",
    "revived",
    "upgrade",
    "revivejs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alexandroit/ng-multiselect-dropdown.git"
  },
  "bugs": {
    "url": "https://github.com/alexandroit/ng-multiselect-dropdown/issues"
  },
  "homepage": "https://github.com/alexandroit/ng-multiselect-dropdown#readme",
  "peerDependencies": {},
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.6",
    "@angular/animations": "21.2.7",
    "@angular/cli": "~21.2.6",
    "@angular/common": "21.2.7",
    "@angular/compiler": "21.2.7",
    "@angular/compiler-cli": "21.2.7",
    "@angular/core": "21.2.7",
    "@angular/forms": "21.2.7",
    "@angular/platform-browser": "21.2.7",
    "@angular/platform-browser-dynamic": "21.2.7",
    "@angular/router": "21.2.7",
    "@types/jasmine": "~5.1.4",
    "@types/jasminewd2": "~2.0.10",
    "@types/node": "^18.19.76",
    "angular-cli-ghpages": "^0.6.0-rc.2",
    "copyfiles": "^2.0.0",
    "core-js": "^3.32.0",
    "jasmine-core": "~5.1.2",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.1.0",
    "karma-cli": "~2.0.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "^21.2.2",
    "ngx-bootstrap": "^21.0.1",
    "rimraf": "^3.0.0",
    "rxjs": "^7.8.1",
    "ts-node": "~8.3.0",
    "typescript": "~5.9.2",
    "zone.js": "~0.16.1"
  },
  "dependencies": {
    "tslib": "^2.6.2"
  }
}
